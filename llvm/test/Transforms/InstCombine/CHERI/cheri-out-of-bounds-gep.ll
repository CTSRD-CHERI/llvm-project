; CHECK that we don't generate intermediate out-of-bounds GEPs which can strip tags.
define ptr addrspace(200) @foo(ptr addrspace(200) %a, i32 %x) {
; CHECK-LABEL: define ptr addrspace(200) @foo(
; CHECK-SAME: ptr addrspace(200) [[A:%.*]], i32 [[X:%.*]]) addrspace(200) #[[ATTR0:[0-9]+]] {
; CHECK-NEXT:  entry:
; CHECK-NEXT:    [[GEP0:%.*]] = getelementptr inbounds i32, ptr addrspace(200) [[A]], i64 1
; CHECK-NEXT:    [[ADD0:%.*]] = add nsw i32 [[X]], 147456
; CHECK-NEXT:    [[DIV0:%.*]] = sdiv i32 [[ADD0]], 9
; CHECK-NEXT:    [[SUB0:%.*]] = add nsw i32 [[DIV0]], -16384
; CHECK-NEXT:    [[IDX:%.*]] = sext i32 [[SUB0]] to i64
; CHECK-NEXT:    [[GEP1:%.*]] = getelementptr inbounds i32, ptr addrspace(200) [[GEP0]], i64 [[IDX]]
; CHECK-NEXT:    ret ptr addrspace(200) [[GEP1]]
;
entry:
  %gep0 = getelementptr inbounds i32, ptr addrspace(200) %a, i64 1
  %add0 = add nsw i32 %x, 147456
  %div0 = sdiv i32 %add0, 9
  %sub0 = add nsw i32 %div0, -16384
  %idx = sext i32 %sub0 to i64
  %gep1 = getelementptr inbounds i32, ptr addrspace(200) %gep0, i64 %idx
  ret ptr addrspace(200) %gep1
}
